string radar_id  # 雷达实例标识（如 front/right/port），区分不同 mmWave 设备
float64 x        # 纵向位置 (m, VCS)
float64 y        # 横向位置 (m, VCS)
float64 v_x      # 纵向速度 (m/s)
float64 v_y      # 横向速度 (m/s)
float64 size_w   # 包围盒宽度/横向尺寸 (m)
float64 size_l   # 包围盒长度/纵向尺寸 (m)
float64 size_h   # 包围盒高度 (m)
uint8 objmotion_status  # 动静状态: 0 静止, 1 运动
uint32 track_id  # 航迹 ID
