string radar_id  # 雷达实例标识（如 front/right/port），区分不同 mmWave 设备
float64 x        # 聚类中心相对坐标 X（米）
float64 y        # 聚类中心相对坐标 Y（米）
float64 v_x      # 目标速度矢量 X（米/秒），可为绝对或相对速度
float64 v_y      # 目标速度矢量 Y（米/秒）
float64 size_w   # 点云聚类估算宽度（米）
float64 size_l   # 点云聚类估算长度（米）
float64 size_h   # 点云聚类估算高度（米，仅用于高度分类，不参与 EKF 追踪）
float64 snr      # 信噪比，融合节点依此调节尺寸置信度
