Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Targets (Markers)1
        - /Target Paths1
      Splitter Ratio: 0.5
    Tree Height: 576
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 10
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 160
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Targets (Markers)
      Namespaces:
        "": true
      Topic: /sim/ground_truth_markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Vision Front Markers
      Namespaces:
        vision_detections: true
      Topic: /vision/front/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Vision Right Markers
      Namespaces:
        vision_detections: true
      Topic: /vision/right/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Vision Rear Markers
      Namespaces:
        vision_detections: true
      Topic: /vision/rear/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Vision Left Markers
      Namespaces:
        vision_detections: true
      Topic: /vision/left/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: AIS Markers
      Namespaces:
        ais_labels: true
      Topic: /ais/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Nav Radar Markers
      Namespaces:
        nav_radar_targets: true
      Topic: /nav_radar/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Mmwave Front Markers
      Namespaces:
        mmwave_targets: true
        mmwave_velocity: true
      Topic: /mmwave/front/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Mmwave Right Markers
      Namespaces:
        mmwave_targets: true
        mmwave_velocity: true
      Topic: /mmwave/right/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Mmwave Rear Markers
      Namespaces:
        mmwave_targets: true
        mmwave_velocity: true
      Topic: /mmwave/rear/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Mmwave Left Markers
      Namespaces:
        mmwave_targets: true
        mmwave_velocity: true
      Topic: /mmwave/left/markers
      Queue Size: 10
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Global Fusion Markers
      Namespaces:
        global_position: true
        global_velocity: true
        global_info: true
      Topic: /fusion/global_markers
      Queue Size: 10
      Value: true
  Enabled: true
  Global Options:
    Background Color: 3; 3; 3
    Fixed Frame: base_link
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
    - Class: rviz_default_plugins/SetInitialPose
      Theta std deviation: 0.2617993950843811
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz_default_plugins/SetGoal
      Theta std deviation: 0.2617993950843811
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 200
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.785
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 0.785
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 882
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: false
  Width: 1600
  X: 40
  Y: 40
